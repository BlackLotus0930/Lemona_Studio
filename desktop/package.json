{
  "name": "lemona-desktop",
  "version": "0.9.0",
  "description": "Lemona Desktop Application",
  "main": "dist/desktop/main/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.preload.json",
    "build:main": "tsc",
    "build:preload": "tsc -p tsconfig.preload.json",
    "dev": "npm run build && electron dist/desktop/main/index.js",
    "dev:watch": "tsc --watch & electron dist/desktop/main/index.js",
    "start": "electron dist/desktop/main/index.js",
    "predist": "node -e \"try { const fs = require('fs'); const path = require('path'); const canvasPath = path.join(__dirname, 'node_modules', 'pdfjs-dist', 'node_modules', 'canvas'); if (fs.existsSync(canvasPath)) { fs.rmSync(canvasPath, { recursive: true, force: true }); console.log('Removed pdfjs-dist canvas dependency before dist'); } } catch(e) {}\"",
    "dist": "npm run build:all && electron-builder",
    "dist:win": "npm run build:all && electron-builder --win",
    "dist:mac": "npm run build:all && electron-builder --mac",
    "dist:linux": "npm run build:all && electron-builder --linux",
    "build:all": "cd ../frontend && npm run build && cd ../desktop && npm run build",
    "prebuild": "node -e \"try { const fs = require('fs'); const path = require('path'); const canvasPath = path.join(__dirname, 'node_modules', 'pdfjs-dist', 'node_modules', 'canvas'); if (fs.existsSync(canvasPath)) { fs.rmSync(canvasPath, { recursive: true, force: true }); console.log('Removed pdfjs-dist canvas dependency before build'); } } catch(e) {}\"",
    "postinstall": "node -e \"try { const fs = require('fs'); const path = require('path'); const canvasPath = path.join(__dirname, 'node_modules', 'pdfjs-dist', 'node_modules', 'canvas'); if (fs.existsSync(canvasPath)) { fs.rmSync(canvasPath, { recursive: true, force: true }); console.log('Removed pdfjs-dist canvas dependency'); } } catch(e) {}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tiptap/extension-image": "^3.14.0",
    "@tiptap/extension-link": "^3.14.0",
    "@tiptap/extension-text-align": "^3.14.0",
    "@tiptap/extension-text-style": "^3.14.0",
    "@tiptap/extension-underline": "^3.14.0",
    "@tiptap/html": "^3.14.0",
    "@tiptap/starter-kit": "^3.14.0",
    "axios": "^1.13.2",
    "docx": "^9.5.1",
    "happy-dom": "^20.0.2",
    "hnswlib-node": "^3.0.0",
    "mammoth": "^1.11.0",
    "openai": "^6.15.0",
    "orderedmap": "^2.1.1",
    "pdfjs-dist": "^5.4.530",
    "pdfkit": "^0.17.2",
    "prosemirror-history": "^1.5.0",
    "prosemirror-model": "^1.25.0",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.10.5",
    "prosemirror-view": "^1.41.4",
    "puppeteer": "^24.34.0",
    "rope-sequence": "^1.3.4",
    "tiktoken": "^1.0.22",
    "w3c-keyname": "^2.2.0"
  },
  "devDependencies": {
    "@electron/node-gyp": "^10.2.0-electron.2",
    "@types/node": "^20.10.5",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.lemona.desktop",
    "productName": "Lemona",
    "beforeBuild": null,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "!node_modules/**/*.{md,ts,tsx}",
      "!**/*.{ts,tsx,map}",
      "!**/test/**/*",
      "!**/tests/**/*",
      "!node_modules/happy-dom/**/test/**/*",
      "!node_modules/happy-dom/**/tests/**/*",
      "!../backend/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/orderedmap/**/*",
      "**/node_modules/prosemirror-model/**/*",
      "**/node_modules/prosemirror-history/**/*",
      "**/node_modules/prosemirror-state/**/*",
      "**/node_modules/prosemirror-transform/**/*",
      "**/node_modules/prosemirror-view/**/*",
      "**/node_modules/rope-sequence/**/*",
      "**/node_modules/w3c-keyname/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../frontend/public/lemonalogo.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "../frontend/public/lemonalogo.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../frontend/public/lemonalogo.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lemona"
    }
  }
}
